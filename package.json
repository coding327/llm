{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "root",
  "private": true,
  "workspaces": [
    "clients/*",
    "services/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "2.9.17",
    "wait-on": "9.0.10"
  }
}
